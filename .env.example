# RainEngine Gateway Configuration

# The AI Provider to use. Valid options: "gemini", "openai"
# If unset, the gateway will fallback to a Mock provider.
RAIN_PROVIDER_KIND=gemini

# Your API Key for the chosen provider
RAIN_PROVIDER_API_KEY=your_api_key_here

# Optional: Override the model
# RAIN_PROVIDER_MODEL=gemini-2.5-flash
